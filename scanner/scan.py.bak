# scanner/scan.py
# High-value automated scanner for normalized targets.

import json
import os
import requests
from datetime import datetime

# HIGH‑VALUE ENGINES ONLY
# Each engine should accept a URL and return a list of dict-like findings
# with keys such as: severity, title, details (optional)
def _try_import(name, fn_name):
    try:
        m = __import__(name)
        return getattr(m, fn_name)
    except Exception:
        print(f"[scanner] Warning: engine {name} not available, skipping")
        return None

check_idor = _try_import('idor_engine', 'check_idor')
check_ssrf = _try_import('ssrf_engine', 'check_ssrf')
check_auth_bypass = _try_import('auth_bypass_engine', 'check_auth_bypass')
check_rate_limit = _try_import('rate_limit_engine', 'check_rate_limit')
check_sensitive_data = _try_import('sensitive_data_engine', 'check_sensitive_data')
check_jwt = _try_import('jwt_engine', 'check_jwt')

OUTPUT_DIR = "data"
DEFAULT_TIMEOUT = 10

def load_programs(path="programs.json"):
    with open(path, "r") as f:
        return json.load(f)

def scan_target(url):
    """Run payout-worthy checks on a single target and return list of findings dicts."""
    findings = []

    engines = [
        check_idor,
        check_ssrf,
        check_auth_bypass,
        check_rate_limit,
        check_sensitive_data,
        check_jwt,
    ]

    # Run each engine and collect results
    for engine in engines:
        try:
            res = engine(url)
            if res:
                # engines may return list of tuples or list of dicts; normalize here
                for item in res:
                    if isinstance(item, dict):
                        findings.append(item)
                    elif isinstance(item, (list, tuple)) and len(item) >= 2:
                        # (severity, title) style
                        findings.append({"severity": item[0], "title": item[1], "details": {}})
                    else:
                        # unknown format, skip
                        continue
        except Exception as e:
            print(f"[scanner] Engine error on {url}: {e}")

    # Basic header checks as fallback if engines didn't produce anything
    try:
        r = requests.get(url, timeout=DEFAULT_TIMEOUT, allow_redirects=True)
        headers = r.headers

        if "Strict-Transport-Security" not in headers:
            findings.append({"severity": "MEDIUM", "title": "Missing Strict-Transport-Security (HSTS)", "details": {}})
        if "Content-Security-Policy" not in headers:
            findings.append({"severity": "MEDIUM", "title": "Missing Content-Security-Policy (CSP)", "details": {}})
        if "X-Frame-Options" not in headers:
            findings.append({"severity": "MEDIUM", "title": "Missing X-Frame-Options", "details": {}})
        if "Server" in headers:
            findings.append({"severity": "LOW", "title": "Server version disclosure", "details": {"server": headers.get("Server")}})
        # cookie checks are best-effort
        for c in r.cookies:
            try:
                # requests' cookie objects don't expose has_nonstandard_attr; be permissive
                if not getattr(c, "httponly", False):
                    findings.append({"severity": "MEDIUM", "title": "Cookie missing HttpOnly flag", "details": {"cookie": c.name}})
            except Exception:
                continue
    except Exception:
        findings.append({"severity": "LOW", "title": "Target unreachable", "details": {}})

    return findings

def _normalize_finding_for_output(f, target, program_name, date):
    """Return a dict with the exact fields pipeline expects."""
    title = f.get("title") or f.get("issue") or "Unknown finding"
    severity = f.get("severity", "LOW")
    impact = f.get("impact", "")
    description = f.get("description") or title
    details = f.get("details", {})

    return {
        "issue": title,
        "severity": severity,
        "impact": impact,
        "description": description,
        "target": target,
        "program": program_name,
        "date": date,
        "details": details
    }

def save_findings(program, findings):
    """Save findings for a program into a clean JSON file. No-op if findings empty."""
    if not findings:
        return

    os.makedirs(OUTPUT_DIR, exist_ok=True)
    date = datetime.utcnow().strftime("%Y-%m-%d")

    program_id = program.get("id", program.get("name", "unknown")).replace(" ", "_")
    filename = f"{program_id}-{date}.json"
    path = os.path.join(OUTPUT_DIR, filename)

    output = []
    program_name = program.get("name", "Unknown Program")
    for f in findings:
        # ensure pipeline-required fields are present
        output.append(_normalize_finding_for_output(f, f.get("target"), program_name, date))

    with open(path, "w") as fp:
        json.dump(output, fp, indent=2)

    print(f"[scanner] Saved: {path}")

def scan_program(program):
    """Scan all normalized targets for a single program and return findings list."""
    targets = program.get("normalized_scope") or program.get("scope") or []
    all_findings = []

    for target in targets:
        print(f"[scanner] Scanning target: {target}")
        findings = scan_target(target)

        # Attach target to each finding if not already present
        for f in findings:
            if not f.get("target"):
                f["target"] = target

        all_findings.extend(findings)

    return all_findings

def main():
    programs = load_programs()
    for program in programs:
        findings = scan_program(program)
        save_findings(program, findings)

if __name__ == "__main__":
    main()
